# ─────────────────────────────────────────────────────────
# Outclaw — Self-Hosted Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Server ──
NODE_ENV=production
PORT=3000
SECRET_KEY_BASE=replace-with-a-64-char-random-string

# ── Database (MySQL) ──
# If using docker-compose, these match the mysql service config
DATABASE_URL=mysql://outclaw:outclaw_pass@localhost:3306/outclaw
DB_ROOT_PASSWORD=outclaw_root_pass
DB_NAME=outclaw
DB_USER=outclaw
DB_PASSWORD=outclaw_pass
DB_PORT=3306

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Authentication ──
# JWT secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-a-64-char-random-string

# ── LLM Provider ──
# Supports OpenAI-compatible APIs (OpenAI, Azure, Anthropic via proxy, local models)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── AlphaClaw (Orchestration Engine) ──
# Path to your AlphaClaw installation or API endpoint
ALPHACLAW_MODE=local
ALPHACLAW_CONFIG_PATH=./alphaclaw.json
# If using remote AlphaClaw instance:
# ALPHACLAW_API_URL=http://localhost:8080
# ALPHACLAW_API_KEY=your-alphaclaw-api-key

# ── Browser Harness ──
# Provides browser automation capabilities to agents
BROWSER_HARNESS_ENABLED=true
BROWSER_HARNESS_ENDPOINT=http://localhost:9222
# Chrome DevTools Protocol endpoint
# If using Docker, the browser-harness container exposes this automatically

# ── File Storage (S3-compatible) ──
# Works with AWS S3, MinIO, DigitalOcean Spaces, Cloudflare R2
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=outclaw
S3_REGION=us-east-1

# ── Email (SMTP) ──
# For notifications and invitations
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── Application ──
APP_URL=http://localhost:3000
APP_NAME=Outclaw
OWNER_EMAIL=admin@yourdomain.com
